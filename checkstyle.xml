<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
 "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
 "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <!-- 文件末尾必须有一个换行符（空行），用 Regexp 匹配最后一行的非换行字符以准确定位到文件末尾 -->
    <module name="RegexpMultiline">
        <property name="format" value="[^\r\n]\z"/>
        <property name="message" value="文件末尾必须有换行符（空行）"/>
    </module>

    <!-- 文件末尾必须有且仅有一个换行符（定位到多余的换行便于删除） -->
    <module name="RegexpMultiline">
        <property name="format" value="(?&lt;=\r?\n)\r?\n\z"/>
        <property name="message" value="文件末尾只能有一个换行符，请删除多余空行"/>
    </module>

    <!-- 文件最大 500 行 -->
    <module name="FileLength">
        <property name="max" value="500"/>
    </module>

    <!-- 每行最多 120 字符 -->
    <module name="LineLength">
        <property name="max" value="120"/>
    </module>

    <!-- 禁止出现两个连续空行（定位到第二个空行便于删除） -->
    <module name="RegexpMultiline">
        <property name="format" value="(?&lt;=\r?\n\s*\r?\n)\s*\r?\n"/>
        <property name="message" value="不能出现两个连续空行"/>
    </module>

    <!-- 类/接口体第一行必须是空行；空类/空接口允许 {} 紧凑写法 -->
    <module name="RegexpMultiline">
        <property name="format" value="(?:class|interface)\s+\w+[^{]*\{[ \t]*\r?\n(?!\s*\r?\n)[ \t]*[^\s\r\n}]"/>
        <property name="message" value="类/接口体第一行必须是空行"/>
    </module>

    <!-- 方法/构造器体第一行必须是空行：仅匹配含 public/private/protected 的声明，避免误伤 if/for/while 等 -->
    <module name="RegexpMultiline">
        <property name="format" value="(?:public|private|protected)\s+[^\n]*\)[ \t]*\{[ \t]*\r?\n(?!\s*\r?\n)[ \t]*[^\s\r\n]"/>
        <property name="message" value="方法体第一行必须是空行"/>
    </module>

    <!-- 任何空行都不能包含空格或制表符，必须完全空白（RegexpSingleline 逐行检查，行号准确） -->
    <module name="RegexpSingleline">
        <property name="format" value="^[ \t]+$"/>
        <property name="message" value="空行不能包含空格或制表符，请删除多余空白"/>
    </module>

    <!-- 禁止行尾空格或制表符 -->
    <module name="RegexpSingleline">
        <property name="format" value="[ \t]+$"/>
        <property name="message" value="行尾不能有空格或制表符，请删除"/>
    </module>

    <module name="TreeWalker">

        <!-- 方法、构造器之间必须有空行 -->
        <module name="EmptyLineSeparator">
            <property name="allowMultipleEmptyLines" value="false"/>
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="tokens"
                      value="METHOD_DEF, CTOR_DEF"/>
        </module>

        <!-- 方法最多 80 行 -->
        <module name="MethodLength">
            <property name="max" value="80"/>
        </module>

        <!-- 方法参数最多 5 个 -->
        <module name="ParameterNumber">
            <property name="max" value="5"/>
        </module>

        <!-- if 必须有 {} -->
        <module name="NeedBraces"/>

        <!-- 禁止未使用的导入 -->
        <module name="UnusedImports"/>

    </module>

</module>